// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Test {
  id    String @id @default(cuid())
  title String
}

model User {
  id             String          @id
  name           String
  email          String
  emailVerified  Boolean         @default(false)
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  accounts       Account[]
  userProfile    UserProfile?
  userPreference UserPreference?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model CorsairIntegration {
  id        String           @id
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  name      String
  config    Json             @default("{}")
  dek       String?
  accounts  CorsairAccount[]

  @@map("corsair_integrations")
}

model CorsairAccount {
  id            String             @id
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  tenantId      String             @map("tenant_id")
  integrationId String             @map("integration_id")
  config        Json               @default("{}")
  dek           String?
  integration   CorsairIntegration @relation(fields: [integrationId], references: [id])
  entities      CorsairEntity[]
  events        CorsairEvent[]

  @@map("corsair_accounts")
}

model CorsairEntity {
  id         String         @id
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  accountId  String         @map("account_id")
  entityId   String         @map("entity_id")
  entityType String         @map("entity_type")
  version    String
  data       Json           @default("{}")
  account    CorsairAccount @relation(fields: [accountId], references: [id])

  @@map("corsair_entities")
}

model CorsairEvent {
  id        String         @id
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  accountId String         @map("account_id")
  eventType String         @map("event_type")
  payload   Json           @default("{}")
  status    String?
  account   CorsairAccount @relation(fields: [accountId], references: [id])

  @@map("corsair_events")
}

// ─── Core user data ──────────────────────────────────────────────────────

model UserProfile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  gmailAddress String?  @map("gmail_address")
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailThreads       EmailThread[]
  emails             Email[]
  drafts             Draft[]
  labels             Label[]
  contacts           Contact[]
  webhooks           Webhook[]
  agentConversations AgentConversation[]
  calendars          Calendar[]
  calendarEvents     CalendarEvent[]

  @@map("user_profiles")
}

model UserPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  theme               String?
  emailSignature      String?  @map("email_signature")
  keyboardShortcuts   Json?    @map("keyboard_shortcuts")
  readingPaneEnabled  Boolean  @default(true) @map("reading_pane_enabled")
  readingPanePosition String?  @map("reading_pane_position")
  autoAdvance         Boolean  @default(false) @map("auto_advance")
  defaultSendDelay    Int?     @map("default_send_delay")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Email ───────────────────────────────────────────────────────────────

model EmailThread {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  gmailThreadId String    @map("gmail_thread_id")
  subject       String?
  snippet       String?
  participants  Json?
  isRead        Boolean   @default(false) @map("is_read")
  isStarred     Boolean   @default(false) @map("is_starred")
  isArchived    Boolean   @default(false) @map("is_archived")
  isTrashed     Boolean   @default(false) @map("is_trashed")
  priority      String?
  unreadCount   Int       @default(0) @map("unread_count")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails      Email[]
  drafts      Draft[]

  @@unique([userId, gmailThreadId])
  @@index([userId])
  @@map("email_threads")
}

model Email {
  id             String    @id @default(uuid())
  threadId       String    @map("thread_id")
  userId         String    @map("user_id")
  gmailMessageId String    @map("gmail_message_id")
  fromAddress    String    @map("from_address")
  fromName       String?   @map("from_name")
  toAddresses    Json      @map("to_addresses")
  ccAddresses    Json?     @map("cc_addresses")
  bccAddresses   Json?     @map("bcc_addresses")
  subject        String?
  bodyHtml       String?   @map("body_html")
  bodyText       String?   @map("body_text")
  labels         Json?
  isRead         Boolean   @default(false) @map("is_read")
  isSent         Boolean   @default(false) @map("is_sent")
  priority       String?
  aiSummary      String?   @map("ai_summary")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  thread      EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userProfile UserProfile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments EmailAttachment[]

  @@unique([userId, gmailMessageId])
  @@index([threadId])
  @@index([userId])
  @@map("emails")
}

model EmailAttachment {
  id                String   @id @default(uuid())
  emailId           String   @map("email_id")
  gmailAttachmentId String   @map("gmail_attachment_id")
  filename          String
  mimeType          String   @map("mime_type")
  sizeBytes         Int      @map("size_bytes")
  createdAt         DateTime @default(now()) @map("created_at")

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("email_attachments")
}

model Draft {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  threadId     String?  @map("thread_id")
  gmailDraftId String?  @map("gmail_draft_id")
  toAddresses  Json     @map("to_addresses")
  ccAddresses  Json?    @map("cc_addresses")
  bccAddresses Json?    @map("bcc_addresses")
  subject      String?
  bodyHtml     String?  @map("body_html")
  bodyText     String?  @map("body_text")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userProfile UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread      EmailThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threadId])
  @@map("drafts")
}

model Label {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  gmailLabelId String   @map("gmail_label_id")
  name         String
  color        String?
  type         String?
  messageCount Int      @default(0) @map("message_count")
  unreadCount  Int      @default(0) @map("unread_count")
  createdAt    DateTime @default(now()) @map("created_at")

  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailLabelId])
  @@index([userId])
  @@map("labels")
}

// ─── Calendar ────────────────────────────────────────────────────────────

model Calendar {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  googleCalendarId String   @map("google_calendar_id")
  name             String
  color            String?
  isPrimary        Boolean  @default(false) @map("is_primary")
  isVisible        Boolean  @default(true) @map("is_visible")
  accessRole       String?  @map("access_role")
  createdAt        DateTime @default(now()) @map("created_at")

  userProfile UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      CalendarEvent[]

  @@unique([userId, googleCalendarId])
  @@index([userId])
  @@map("calendars")
}

model CalendarEvent {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  calendarId     String   @map("calendar_id")
  googleEventId  String   @map("google_event_id")
  title          String
  description    String?
  location       String?
  startTime      DateTime @map("start_time")
  endTime        DateTime @map("end_time")
  isAllDay       Boolean  @default(false) @map("is_all_day")
  status         String?
  recurrenceRule String?  @map("recurrence_rule")
  meetLink       String?  @map("meet_link")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userProfile UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendar    Calendar        @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  attendees   EventAttendee[]

  @@index([userId])
  @@index([calendarId])
  @@map("calendar_events")
}

model EventAttendee {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  email       String
  displayName String?  @map("display_name")
  rsvpStatus  String?  @map("rsvp_status")
  isOrganizer Boolean  @default(false) @map("is_organizer")
  createdAt   DateTime @default(now()) @map("created_at")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_attendees")
}

// ─── Contacts ────────────────────────────────────────────────────────────

model Contact {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  email         String
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  emailCount    Int       @default(0) @map("email_count")
  lastEmailedAt DateTime? @map("last_emailed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
  @@map("contacts")
}

// ─── Webhooks ────────────────────────────────────────────────────────────

model Webhook {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  service     String
  pubSubTopic String?   @map("pub_sub_topic")
  historyId   String?   @map("history_id")
  channelId   String?   @map("channel_id")
  resourceId  String?   @map("resource_id")
  expiry      DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")
  renewedAt   DateTime? @map("renewed_at")

  userProfile UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webhooks")
}

// ─── Agent chat ──────────────────────────────────────────────────────────

model AgentConversation {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  title           String?
  contextSnapshot Json?    @map("context_snapshot")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  userProfile UserProfile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AgentMessage[]

  @@index([userId])
  @@map("agent_conversations")
}

model AgentMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String
  toolCalls      Json?    @map("tool_calls")
  toolResults    Json?    @map("tool_results")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("agent_messages")
}
